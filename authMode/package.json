{
  "name": "authenik8-app",
  "description": "Authenik8 generated Express auth app",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "npx prisma@5.22.0 generate && ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "postinstall": "npx prisma@5.22.0 generate"
  },
  "dependencies": {
    "authenik8-core": "^1.0.3",
    "express": "^4.19.2",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0",
    "prisma": "5.22.0"
  }
}